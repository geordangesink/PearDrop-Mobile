{
  "name": "pear-drops-mobile",
  "productName": "PearDrop",
  "version": "0.2.0",
  "upgrade": "pear://ididi1cou1u7fcai161tc3ejggn1opm6ufcrzfz5dt8gymi1889y",
  "main": "index.ts",
  "scripts": {
    "postinstall": "node scripts/patch-expo-constants-podspec.cjs",
    "eas-build-post-install": "npm run bundle:bare",
    "bundle:bare": "npx bare-pack --host ios-arm64 --host ios-arm64-simulator --host ios-x64-simulator --host android-arm64 --linked --out ./src/worker.bundle.js ./workers/index.js",
    "prebuild": "npx expo prebuild",
    "ios": "RCT_USE_RN_DEP=0 RCT_USE_PREBUILT_RNCORE=0 expo run:ios",
    "android": "expo run:android",
    "ios:prod-relay": "RCT_USE_RN_DEP=0 RCT_USE_PREBUILT_RNCORE=0 EXPO_PUBLIC_RELAY_URL=wss://pear-drops.up.railway.app expo run:ios",
    "ipad:prod-relay": "RCT_USE_RN_DEP=0 RCT_USE_PREBUILT_RNCORE=0 EXPO_PUBLIC_RELAY_URL=wss://pear-drops.up.railway.app expo run:ios --device \"iPad Pro 13-inch (M4)\"",
    "android:prod-relay": "EXPO_PUBLIC_RELAY_URL=wss://pear-drops.up.railway.app expo run:android",
    "lint": "lunte",
    "format": "prettier . --write",
    "production:ios": "npx expo run:ios --configuration Release",
    "production:android": "npx expo run:android --variant release",
    "test": "node --test test/*.test.js"
  },
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@hyperswarm/dht-relay": "^0.4.3",
    "b4a": "^1.8.0",
    "bare-path": "^3.0.0",
    "bare-rpc": "^1.1.0",
    "bare-storage": "^1.1.0",
    "expo": "~55.0.11",
    "expo-build-properties": "~55.0.11",
    "expo-clipboard": "~55.0.11",
    "expo-crypto": "~15.0.7",
    "expo-document-picker": "~55.0.11",
    "expo-file-system": "~55.0.14",
    "expo-haptics": "^55.0.14",
    "expo-media-library": "~55.0.14",
    "expo-status-bar": "~55.0.5",
    "fflate": "^0.8.2",
    "pear-drop-core": "^0.6.0",
    "pear-mobile": "^4.2.0",
    "pear-runtime-react-native": "^2.0.1",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-bare-kit": "^0.12.3",
    "react-native-webrtc": "^124.0.7",
    "sodium-javascript": "^0.8.0"
  },
  "devDependencies": {
    "@react-native/metro-config": "^0.84.0",
    "@types/react": "~19.2.10",
    "bare-pack": "^2.0.0",
    "hyperdht": "^6.19.1",
    "lunte": "^1.6.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
